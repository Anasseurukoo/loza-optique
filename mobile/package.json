{
  "name": "loza-optique-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:ar": "node --experimental-strip-types --test tests/ar-geometry.test.ts",
    "check": "npm run typecheck && npm run test:ar"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.7",
    "expo-camera": "~57.0.3",
    "expo-constants": "~57.0.6",
    "expo-dev-client": "~57.0.2",
    "expo-document-picker": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-nitro-image": "^0.15.1",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-vision-camera": "^5.1.1",
    "react-native-vision-camera-face-detector": "^2.0.6",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^57.0.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nitro-image"
        ],
        "listUnknownPackages": true
      }
    }
  }
}
